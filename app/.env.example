APP_NAME="Grafica Uriah Criativa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=grafica_ecommerce
DB_USERNAME=laravel
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contato@graficaimpacta.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reverb (real-time chat)
REVERB_APP_ID=local-vertice
REVERB_APP_KEY=local-vertice-key
REVERB_APP_SECRET=local-vertice-secret
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=

STOREFRONT_PAYMENT_DRIVER=manual
STOREFRONT_PAYMENT_SUCCESS_REDIRECT=gateway

STOREFRONT_SOCIAL_PROVIDERS=google,facebook,github
STOREFRONT_SOCIAL_STATELESS=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/social/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/social/facebook/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/social/github/callback"

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_TOKEN=
MERCADOPAGO_BASE_URL=https://api.mercadopago.com
MERCADOPAGO_STATEMENT_DESCRIPTOR=URIAH

STOREFRONT_SHIPPING_DRIVER=local
STOREFRONT_ORIGIN_ZIPCODE=01001000
STOREFRONT_ORIGIN_CITY="Sao Paulo"
STOREFRONT_ORIGIN_STATE=SP
STOREFRONT_PICKUP_ENABLED=true
STOREFRONT_PICKUP_LABEL="Retirada no balcão"
STOREFRONT_PICKUP_LEAD_TIME_DAYS=1
STOREFRONT_PICKUP_ADDRESS="Retirada no balcão mediante confirmação do pedido"

MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_BASE_URL=https://www.melhorenvio.com.br/api/v2/me
MELHOR_ENVIO_SANDBOX=false
